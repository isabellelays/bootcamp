# ===========================
# AEM dentro do Magento
# ===========================
/app/code/Bootcamp/crx-quickstart/

# ===========================
# Magento 2
# ===========================

# Dependências do Composer
/vendor/

# Código e metadata gerados
/generated/code/
/generated/metadata/

# Cache, logs, sessões e arquivos temporários
/var/cache/
/var/composer_home/
/var/log/
/var/page_cache/
/var/session/
/var/tmp/
/var/view_preprocessed/

# Assets estáticos compilados
/pub/static/*
!/pub/static/.htaccess

# Media (uploads) — opcional, remova se quiser versionar
/pub/media/*
!/pub/media/.htaccess

# Configurações de ambiente (contém senhas/credenciais)
/app/etc/env.php
/app/etc/config.php

